# Environment file loaded by every Support Automation systemd unit.
# Install to /etc/support-automation/env on the production VM.
#
# Mode is per-source — see docs/HANDBOOK.md sections A-G for the
# per-source going-live recipes. The defaults below are safe-by-default
# (everything in local mode reading fixtures).

# Database — required.
SUPPORT_AUTOMATION_DATABASE_URL=postgresql+psycopg://support_automation@localhost/support_automation

# Language model chain — leave as-is unless you've set up Claude Code
# on the VM with a different login.
SUPPORT_AUTOMATION_LANGUAGE_MODEL_PRIMARY=claude_code

# Source modes — flip to "real" once the matching secrets/ file is in place.
SUPPORT_AUTOMATION_FEEDBACK_GMAIL_MODE=local
SUPPORT_AUTOMATION_FEEDBACK_PLAY_MODE=local
SUPPORT_AUTOMATION_FEEDBACK_APPLE_MODE=local
SUPPORT_AUTOMATION_KNOWLEDGE_CONFLUENCE_MODE=local
SUPPORT_AUTOMATION_KNOWLEDGE_JIRA_MODE=local
SUPPORT_AUTOMATION_KNOWLEDGE_SHEETS_MODE=local

# Notification mode — keep `local` for the first 24-48 h post-deploy
# (digests are written to /var/log/support-automation/digests/),
# then flip to `real` once you've reviewed several digest outputs.
SUPPORT_AUTOMATION_NOTIFICATION_MODE=local
